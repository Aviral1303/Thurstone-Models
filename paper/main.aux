\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces RQ4: fitted tie curves versus empirical tie rates, pooled over windows with vote weights, each model binned by its \emph  {own} fitted gaps. The two mechanisms agree at the origin but decay at genuinely different rates; the empirical decay lies between them, both undershoot near toss-ups, and the region where the shapes separate most ($|\hat  g| \gtrsim 1.2$, shaded) carries under $10\%$ of votes. Source: \texttt  {rq4\_tie\_curve\_bins.csv}.}}{11}{figure.5}\protected@file@percent }
\newlabel{fig:rq4curves}{{5}{11}{RQ4: fitted tie curves versus empirical tie rates, pooled over windows with vote weights, each model binned by its \emph {own} fitted gaps. The two mechanisms agree at the origin but decay at genuinely different rates; the empirical decay lies between them, both undershoot near toss-ups, and the region where the shapes separate most ($|\hat g| \gtrsim 1.2$, shaded) carries under $10\%$ of votes. Source: \texttt {rq4\_tie\_curve\_bins.csv}}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces RQ4 drift trajectories (first-class output). \textbf  {(a)} Per-window profiled tie parameters: Davidson $\hat  \nu $ rises $0.376 \to 0.559$ and the lattice width $\hat  u$ rises $0.594 \to 0.803$, tracking the quality-tie share ($13.1\% \to 20.45\%$). The windowed $\hat  u$ trajectory's endpoints independently reproduce the two earlier one-shot profile fits (dotted). \textbf  {(b)} Implied half-max tie-band half-widths: the $\sim \!1.7\times $ shape difference is stable even as both parameters drift. Source: \texttt  {rq4\_param\_trajectories.csv}.}}{11}{figure.6}\protected@file@percent }
\newlabel{fig:rq4traj}{{6}{11}{RQ4 drift trajectories (first-class output). \textbf {(a)} Per-window profiled tie parameters: Davidson $\hat \nu $ rises $0.376 \to 0.559$ and the lattice width $\hat u$ rises $0.594 \to 0.803$, tracking the quality-tie share ($13.1\% \to 20.45\%$). The windowed $\hat u$ trajectory's endpoints independently reproduce the two earlier one-shot profile fits (dotted). \textbf {(b)} Implied half-max tie-band half-widths: the $\sim \!1.7\times $ shape difference is stable even as both parameters drift. Source: \texttt {rq4\_param\_trajectories.csv}}{figure.6}{}}
