\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces RQ3: per-window mean calibration delta (primary width $u=0.5855$), in MPD units. Eleven of thirteen windows show sub-practical BT-leaning deltas inside the equivalence band; a single window carries a $+5.79\times $MPD excursion. The pre-registered classifier returns \emph  {inconclusive} on exactly this pattern: effect size and sign consistency disagree. Source: \texttt  {rq3\_window\_table\_u0.5855.csv}.}}{9}{figure.4}\protected@file@percent }
\newlabel{fig:rq3}{{4}{9}{RQ3: per-window mean calibration delta (primary width $u=0.5855$), in MPD units. Eleven of thirteen windows show sub-practical BT-leaning deltas inside the equivalence band; a single window carries a $+5.79\times $MPD excursion. The pre-registered classifier returns \emph {inconclusive} on exactly this pattern: effect size and sign consistency disagree. Source: \texttt {rq3\_window\_table\_u0.5855.csv}}{figure.4}{}}
